OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Modelo barato e bom em tool calling. Outras opcoes: openai/gpt-4o-mini,
# qwen/qwen-2.5-72b-instruct, meta-llama/llama-3.1-405b-instruct.
LLM_MODEL=meta-llama/llama-3.3-70b-instruct
LLM_TEMPERATURE=0.4
LLM_MAX_TOKENS=1500
# Embeddings: Llama nao tem embeddings no OpenRouter, mantemos OpenAI (custo desprezivel).
EMBEDDING_MODEL=openai/text-embedding-3-small

SERPAPI_API_KEY=
SERPAPI_BASE_URL=https://serpapi.com/search

SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_INSERT_RPC=insert_mcqueen_document
SUPABASE_MATCH_RPC=match_mcqueen_documents
SUPABASE_MATCH_TABLE=mcqueen_documents
SUPABASE_EMBEDDING_DIM=1536
SUPABASE_MATCH_TOP_K=4
SUPABASE_MATCH_THRESHOLD=0.78

API_HOST=0.0.0.0
API_PORT=8000
# Em DEV, o regex abaixo cobre qualquer porta de localhost/127.0.0.1 (Vite as vezes
# salta de 5173 pra 5174 quando a porta esta ocupada). Em PROD, defina CORS_ORIGINS
# com a lista exata de origens (e deixe CORS_ORIGIN_REGEX vazio).
CORS_ORIGIN_REGEX=^http://(localhost|127\.0\.0\.1):\d+$
CORS_ORIGINS=
LOG_LEVEL=info

MCQUEEN_MAX_ITERATIONS=10
HTTP_TIMEOUT_SECONDS=30
